{
  "watch": [
    "index.js",
    "server.js",
    "config.js"
  ],
  "ignore": [
    "node_modules/**/*",
    "temp/**/*",
    "*.log",
    "*.csv",
    "*.xlsx",
    "*.pdf",
    "*.webp",
    "*.png",
    "public/**/*",
    ".git/**/*",
    "*.md",
    "*.bat",
    "*.ps1",
    "*.txt",
    "*.env",
    "*.env.*",
    "desktop.ini",
    "*.swp",
    "*.swo",
    ".DS_Store",
    "Thumbs.db",
    "ehthumbs.db",
    "*.pid",
    "*.seed",
    "*.pid.lock",
    "coverage/**/*",
    ".nyc_output/**/*",
    "ersAnnikaRydénOneDriveClientFlow/**/*",
    "*.backup",
    "*-backup.js",
    "*-new.js",
    "check-*.js",
    "test-*.js",
    "test_*.js"
  ],
  "ext": "js,json",
  "exec": "node index.js",
  "delay": 2500,
  "verbose": true,
  "restartable": "rs",
  "colours": true,
  "signal": "SIGTERM",
  "killTimeout": 5000
}
